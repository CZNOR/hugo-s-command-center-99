{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/push/notify", "schedule": "* * * * *" },
    { "path": "/api/push/ritual?mode=morning", "schedule": "0 2 * * *" },
    { "path": "/api/push/ritual?mode=evening", "schedule": "0 12 * * *" },
    { "path": "/api/push/weekly-digest", "schedule": "0 13 * * 0" }
  ]
}
